// stress test GC with arrays
fun makeArrays() {
    var i = 0;
    while (i < 100) {
        var arr = #[1, 2, 3, 4, 5];
        i = i + 1;
    }
}

makeArrays();
print "GC survived";

// arrays with object values (strings go on heap, good GC test)
var strs = #["hello", "world", "rain", "language"];
print strs#[0];
print strs#[3];

// modify after many allocations
var nums = #[10, 20, 30];
nums#[1] = 999;
print nums;
