benutzen "http";
benutzen "json";

// GET
var res = http::get("https://jsonplaceholder.typicode.com/todos/1");
print res.status;
var todo = json::parse(res.body);
print todo.title;

// POST
var payload = json::stringify(json::parse("{\"title\": \"rain todo\", \"completed\": false, \"userId\": 1}"));
var res2 = http::post("https://jsonplaceholder.typicode.com/todos", payload);
print res2.status;
var created = json::parse(res2.body);
print created.title;
print created.id;
