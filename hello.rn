benutzen "time";

print time::now();
print time::date();
print time::clock();
print time::datetime();
print time::year();
print time::month();
print time::day();
print time::hour();
print time::minute();
print time::second();
print time::weekday();
print time::monthName();

var ts = time::now();
print time::format(ts, "%Y/%m/%d %H:%M:%S");
